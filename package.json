{
  "name": "24therapy",
  "version": "1.0.0",
  "private": true,
  "description": "24Therapy.ai — AI-Native Mental Health Operating System",
  "workspaces": [
    "apps/*",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "pg": "^8.13.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "20.x",
    "pnpm": ">=9.x"
  }
}
