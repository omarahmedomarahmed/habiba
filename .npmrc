# ============================================================
# pnpm configuration for 24Therapy monorepo
# ============================================================

# Use node_modules layout (required for Next.js and Vercel compatibility)
node-linker=hoisted

# Allow scripts to run (needed for postinstall hooks)
enable-pre-post-scripts=true

# Hoist all packages to root node_modules (Vercel/Next.js compatibility)
# This ensures next, react etc. are found without shamefully-hoist
shamefully-hoist=true

# Strict peer dependencies off (compatibility across workspace packages)
strict-peer-dependencies=false

# Auto-install peer dependencies
auto-install-peers=true
