# =============================================================
# 24Therapy Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
PORT=3001
APP_NAME="24Therapy Mental Health OS"
APP_URL=http://localhost:3001
FRONTEND_THERAPIST_URL=http://localhost:3000
FRONTEND_PATIENT_URL=http://localhost:3002
FRONTEND_ADMIN_URL=http://localhost:3003
FRONTEND_WEB_URL=http://localhost:3004

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/24therapy
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=24therapy
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false

# For production (Supabase, Neon, PlanetScale, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ============================================================
# REDIS (Caching + Sessions + Queues)
# ============================================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this-in-prod
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-this
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# ============================================================
# AI PROVIDERS
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_ORG_ID=org-your-org-id
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# AI Cost Limits
AI_MONTHLY_BUDGET_USD=10000
AI_ALERT_THRESHOLD_PCT=80
AI_MAX_TOKENS_PER_REQUEST=8192

# ============================================================
# STRIPE (Billing)
# ============================================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
STRIPE_CONNECT_CLIENT_ID=ca_your-connect-client-id

# Plan Price IDs
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly
STRIPE_PRICE_ENTERPRISE=price_enterprise_custom

# ============================================================
# EMAIL (SendGrid)
# ============================================================
SENDGRID_API_KEY=SG.your-sendgrid-api-key
EMAIL_FROM=noreply@24therapy.ai
EMAIL_FROM_NAME="24Therapy"
EMAIL_SUPPORT=support@24therapy.ai
EMAIL_COMPLIANCE=compliance@24therapy.ai

# ============================================================
# SMS (Twilio)
# ============================================================
TWILIO_ACCOUNT_SID=ACyour-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# STORAGE (AWS S3 / Cloudflare R2)
# ============================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=24therapy-recordings
AWS_S3_BUCKET_ATTACHMENTS=24therapy-attachments
AWS_CLOUDFRONT_URL=https://cdn.24therapy.ai

# For Cloudflare R2 (alternative)
# R2_ACCESS_KEY_ID=your-r2-key
# R2_SECRET_ACCESS_KEY=your-r2-secret
# R2_BUCKET=24therapy
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# ============================================================
# VIDEO (Daily.co WebRTC)
# ============================================================
DAILY_API_KEY=your-daily-api-key
DAILY_DOMAIN=your-domain.daily.co

# ============================================================
# WEBSOCKETS
# ============================================================
WS_PORT=3001
SOCKET_IO_SECRET=your-socket-io-secret

# ============================================================
# VECTOR DATABASE (for AI Memory / RAG)
# ============================================================
# Using pgvector (built into PostgreSQL)
VECTOR_DIMENSION=1536

# For Pinecone (alternative)
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-east1-gcp
# PINECONE_INDEX=24therapy-memory

# ============================================================
# SEARCH (OpenSearch / Elasticsearch)
# ============================================================
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# ============================================================
# MONITORING & OBSERVABILITY
# ============================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development

# Datadog (optional)
# DATADOG_API_KEY=your-datadog-key
# DATADOG_APP_KEY=your-datadog-app-key

# ============================================================
# COMPLIANCE & SECURITY
# ============================================================
HIPAA_MODE=true
GDPR_MODE=true
AUDIT_LOG_RETENTION_DAYS=2555
DATA_ENCRYPTION_KEY=your-32-char-encryption-key-here!
PHI_REDACTION_ENABLED=true
IP_ALLOWLIST=

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AI_MAX_REQUESTS=50

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003,http://localhost:3004
