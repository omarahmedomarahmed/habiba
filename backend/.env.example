# =============================================================
# 24Therapy Backend (backend/) — Environment Variables
# Copy this file to .env and fill in your values.
# Required vars are marked [REQUIRED]. Others have safe defaults.
# =============================================================

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database [REQUIRED] ──────────────────────────────────────────────────────
# PostgreSQL with pgvector extension
# Local: docker compose up postgres
# Production: Neon (https://neon.tech) — free tier available
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/24therapy
DATABASE_SSL=false

# ─── Redis [REQUIRED] ─────────────────────────────────────────────────────────
# Used for: session tokens, rate limiting, AI response caching, queues
# Local: docker compose up redis
# Production: Upstash Redis (https://upstash.com) — free tier available
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# ─── Authentication [REQUIRED] ────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d
BCRYPT_ROUNDS=12
COOKIE_SECRET=change-this-to-another-random-64-char-string

# ─── OpenAI [REQUIRED for AI features] ───────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_MAX_TOKENS=4096

# ─── Email [REQUIRED for auth flows] ─────────────────────────────────────────
# Option A: SMTP (any provider — Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_your-resend-api-key
EMAIL_FROM=noreply@24therapy.ai
EMAIL_FROM_NAME=24Therapy

# ─── Frontend URLs (for email links, CORS) ────────────────────────────────────
FRONTEND_URL=http://localhost:3000
THERAPIST_PORTAL_URL=http://localhost:3001
THERAPIST_URL=http://localhost:3001
PATIENT_PORTAL_URL=http://localhost:3002
PATIENT_URL=http://localhost:3002
ADMIN_PORTAL_URL=http://localhost:3003
ADMIN_URL=http://localhost:3003
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
API_URL=http://localhost:4000
API_VERSION=v1

# ─── Stripe [OPTIONAL — billing not wired yet] ────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ─── Daily.co [OPTIONAL — video sessions] ────────────────────────────────────
# Get from: https://dashboard.daily.co
# DAILY_API_KEY=your-daily-api-key
# DAILY_DOMAIN=your-subdomain.daily.co

# ─── AWS S3 / Cloudflare R2 [OPTIONAL — file uploads] ────────────────────────
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# CLOUDFRONT_URL=https://cdn.24therapy.ai

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_AI_SCRIBE=true
FEATURE_COPILOT=true
FEATURE_RADAR=true
FEATURE_BILLING=true
FEATURE_MARKETPLACE=false
