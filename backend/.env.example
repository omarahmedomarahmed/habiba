# =============================================================
# 24Therapy Backend (backend/) — Environment Variables
# Copy this file to .env and fill in your values.
# Required vars are marked [REQUIRED]. Others have safe defaults.
# =============================================================

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── Database [REQUIRED] ──────────────────────────────────────────────────────
# PostgreSQL with pgvector extension
# Production: Neon (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_SSL=true

# ─── Message Encryption [RECOMMENDED] ────────────────────────────────────────
# AES-256-GCM encryption for all message content at rest.
# Generate with: openssl rand -hex 32
# Without this key, messages are stored as plaintext (still accessible only via auth).
MESSAGE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# ─── Redis [OPTIONAL] ─────────────────────────────────────────────────────────
# Used for: rate limiting, AI response caching. App works without it.
# Production: Upstash Redis (https://upstash.com)
REDIS_URL=rediss://default:password@host:6379
REDIS_TTL=3600

# ─── Authentication [REQUIRED] ────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=30d
BCRYPT_ROUNDS=12
COOKIE_SECRET=change-this-to-another-random-64-char-string

# ─── OpenAI [REQUIRED for AI features] ───────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_MAX_TOKENS=4096

# ─── Email [REQUIRED for auth flows] ─────────────────────────────────────────
# Resend recommended (https://resend.com)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_your-resend-api-key
EMAIL_FROM=noreply@24therapy.ai
EMAIL_FROM_NAME=24Therapy

# ─── Frontend URLs (for email links & CORS) ───────────────────────────────────
# Current Vercel deployment URLs — update when custom domains go live
FRONTEND_URL=https://24-web.vercel.app
THERAPIST_URL=https://24-therapist.vercel.app
PATIENT_URL=https://24-patient.vercel.app
ADMIN_URL=https://24-admin.vercel.app
API_URL=https://api-24therapy-production.up.railway.app

# CORS: comma-separated list of allowed origins
CORS_ORIGINS=https://24-web.vercel.app,https://24-therapist.vercel.app,https://24-patient.vercel.app,https://24-admin.vercel.app

# ─── Stripe [OPTIONAL — billing module] ──────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ─── Daily.co [OPTIONAL — video sessions] ────────────────────────────────────
# Get from: https://dashboard.daily.co
# DAILY_API_KEY=your-daily-api-key
# DAILY_DOMAIN=your-subdomain.daily.co

# ─── AWS S3 / Cloudflare R2 [OPTIONAL — file uploads] ────────────────────────
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# S3_BUCKET=your-bucket-name
# CLOUDFRONT_URL=https://cdn.24therapy.ai

# ─── Error Monitoring [OPTIONAL] ─────────────────────────────────────────────
# Sentry — get DSN from https://sentry.io/settings/<org>/projects/<project>/keys/
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── Backup Verification [OPTIONAL] ──────────────────────────────────────────
# Used by scripts/backup-verify.js to compare prod vs staging row counts
# STAGING_DATABASE_URL=postgresql://user:pass@staging.neon.tech/dbname?sslmode=require

# ─── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_AI_SCRIBE=true
FEATURE_COPILOT=true
FEATURE_RADAR=true
FEATURE_BILLING=true
FEATURE_MARKETPLACE=false
