# =============================================================
# 24Therapy Marketing Website (apps/web) — Environment Variables
# Copy this file to .env.local and fill in your values.
# Only variables actually read by code are listed here.
# =============================================================

# ─── Backend API ──────────────────────────────────────────────────────────────
# URL of the deployed NestJS backend — replace with your Railway or other platform URL
NEXT_PUBLIC_API_URL=https://YOUR-RAILWAY-URL.up.railway.app/api/v1

# ─── App URLs (cross-app navigation) ─────────────────────────────────────────
# Current Vercel deployment URLs — update to custom domains when ready
NEXT_PUBLIC_WEB_URL=https://24-web.vercel.app
NEXT_PUBLIC_THERAPIST_URL=https://24-therapist.vercel.app
NEXT_PUBLIC_PATIENT_URL=https://24-patient.vercel.app
NEXT_PUBLIC_ADMIN_URL=https://24-admin.vercel.app

# ─── Legacy aliases (kept for backward compat — prefer the above) ─────────────
NEXT_PUBLIC_SITE_URL=https://24-web.vercel.app
NEXT_PUBLIC_THERAPIST_APP_URL=https://24-therapist.vercel.app
NEXT_PUBLIC_PATIENT_APP_URL=https://24-patient.vercel.app
NEXT_PUBLIC_ADMIN_APP_URL=https://24-admin.vercel.app

# ─── Optional: Error Monitoring ──────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── Optional: Demo booking ───────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/24therapy/demo
