# =============================================================
# 24Therapy Marketing Website (apps/web) — Environment Variables
# Copy this file to .env.local and fill in your values.
# Only variables actually read by code are listed here.
# =============================================================

# ─── Backend API ──────────────────────────────────────────────────────────────
# URL of the NestJS backend (backend/ folder, deployed separately)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── App URLs (cross-app navigation) ─────────────────────────────────────────
# Update these to your Vercel preview URLs or custom domains
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_THERAPIST_APP_URL=http://localhost:3001
NEXT_PUBLIC_PATIENT_APP_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3003

# ─── Optional: Demo booking ───────────────────────────────────────────────────
# Set your Calendly link for the /demo page
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/24therapy/demo
