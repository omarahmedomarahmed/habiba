# =============================================================
# 24Therapy Marketing Website (apps/web) — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# ============================================================
# API & BACKEND
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ============================================================
# APP URLS (for cross-app links)
# ============================================================
NEXT_PUBLIC_THERAPIST_APP_URL=http://localhost:3000
NEXT_PUBLIC_PATIENT_APP_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_APP_URL=http://localhost:3003

# ============================================================
# ANALYTICS
# ============================================================
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog (product analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Segment
NEXT_PUBLIC_SEGMENT_WRITE_KEY=your-segment-write-key

# ============================================================
# FEATURE FLAGS
# ============================================================
NEXT_PUBLIC_ENABLE_BLOG=true
NEXT_PUBLIC_ENABLE_CHANGELOG=true
NEXT_PUBLIC_SHOW_PRICING=true
NEXT_PUBLIC_ENABLE_DEMO_BOOKING=true

# ============================================================
# CONTACT & FORMS
# ============================================================
# HubSpot (contact forms / demo booking)
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=your-portal-id
NEXT_PUBLIC_HUBSPOT_DEMO_FORM_ID=your-form-id

# Calendly (demo scheduling)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/24therapy/demo

# ============================================================
# CONTENT (CMS — optional)
# ============================================================
# Contentful
# CONTENTFUL_SPACE_ID=your-space-id
# CONTENTFUL_ACCESS_TOKEN=your-access-token
# CONTENTFUL_PREVIEW_TOKEN=your-preview-token

# Sanity
# NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
# NEXT_PUBLIC_SANITY_DATASET=production

# ============================================================
# SEO & SOCIAL
# ============================================================
NEXT_PUBLIC_SITE_URL=https://24therapy.com
NEXT_PUBLIC_TWITTER_HANDLE=@24therapy
NEXT_PUBLIC_OG_IMAGE_URL=https://24therapy.com/og-image.png

# ============================================================
# ERROR TRACKING
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=24therapy
SENTRY_PROJECT=web

# ============================================================
# DEPLOYMENT
# ============================================================
# Vercel
VERCEL_URL=
NEXT_PUBLIC_VERCEL_ENV=development
