# =============================================================
# 24Therapy Admin Portal (apps/admin) — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# ============================================================
# API & BACKEND
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3003

# ============================================================
# AUTHENTICATION
# ============================================================
# Admin portal requires separate super-admin JWT
NEXT_PUBLIC_ADMIN_JWT_STORAGE_KEY=admin_access_token
NEXT_PUBLIC_ADMIN_REFRESH_STORAGE_KEY=admin_refresh_token

# IP allowlist for admin access (comma-separated CIDR or IPs)
# ADMIN_IP_ALLOWLIST=10.0.0.0/8,203.0.113.42

# ============================================================
# SECURITY
# ============================================================
# Force MFA for all admin users
NEXT_PUBLIC_MFA_REQUIRED=true
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=120
NEXT_PUBLIC_IDLE_TIMEOUT_MINUTES=20

# ============================================================
# ANALYTICS & MONITORING
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Internal metrics
NEXT_PUBLIC_METRICS_REFRESH_MS=30000

# ============================================================
# ERROR TRACKING
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=24therapy
SENTRY_PROJECT=admin-portal

# ============================================================
# FEATURE FLAGS (Admin Controls)
# ============================================================
# These control visibility of admin-only dangerous actions
NEXT_PUBLIC_ENABLE_USER_IMPERSONATION=true
NEXT_PUBLIC_ENABLE_ACCOUNT_DELETION=false
NEXT_PUBLIC_ENABLE_MANUAL_BILLING=true
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_AI_COST_CONTROLS=true

# ============================================================
# EXPORT LIMITS
# ============================================================
NEXT_PUBLIC_MAX_EXPORT_ROWS=50000
NEXT_PUBLIC_AUDIT_LOG_EXPORT_DAYS=365

# ============================================================
# BILLING ADMIN
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ============================================================
# COMMUNICATIONS
# ============================================================
# For sending admin notifications
NEXT_PUBLIC_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# ============================================================
# DEPLOYMENT
# ============================================================
VERCEL_URL=
NEXT_PUBLIC_VERCEL_ENV=development

# Note: Admin portal should NEVER be publicly accessible.
# Use VPN, IP allowlist, or private deployment only.
