{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@24therapy/admin",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://cdn.24therapy.ai; connect-src 'self' https://api.24therapy.ai;" }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://api.24therapy.ai/api/v1",
    "NEXT_PUBLIC_SITE_URL": "https://admin.24therapy.ai",
    "NEXT_PUBLIC_WEB_URL": "https://24therapy.ai"
  }
}
