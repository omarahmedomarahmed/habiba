# =============================================================
# 24Therapy Patient Portal (apps/patient) — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# ============================================================
# API & BACKEND
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3002

# ============================================================
# AUTHENTICATION
# ============================================================
NEXT_PUBLIC_JWT_STORAGE_KEY=patient_access_token
NEXT_PUBLIC_REFRESH_STORAGE_KEY=patient_refresh_token

# ============================================================
# VIDEO (Daily.co WebRTC)
# ============================================================
NEXT_PUBLIC_DAILY_DOMAIN=your-domain.daily.co

# ============================================================
# AI FEATURES
# ============================================================
NEXT_PUBLIC_AI_HOMEWORK_ENABLED=true
NEXT_PUBLIC_AI_INSIGHTS_ENABLED=true
NEXT_PUBLIC_AI_SAFETY_MONITOR_ENABLED=true

# ============================================================
# NOTIFICATIONS
# ============================================================
# Web Push (VAPID keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ============================================================
# PAYMENTS
# ============================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ============================================================
# ANALYTICS
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# ERROR TRACKING
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=24therapy
SENTRY_PROJECT=patient-portal

# ============================================================
# CRISIS RESOURCES
# ============================================================
NEXT_PUBLIC_CRISIS_HOTLINE_US=988
NEXT_PUBLIC_CRISIS_TEXT_LINE=741741
NEXT_PUBLIC_EMERGENCY_NUMBER=911

# ============================================================
# HIPAA / COMPLIANCE
# ============================================================
NEXT_PUBLIC_HIPAA_MODE=true
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=60
NEXT_PUBLIC_IDLE_TIMEOUT_MINUTES=15

# ============================================================
# FEATURE FLAGS
# ============================================================
NEXT_PUBLIC_ENABLE_MESSAGING=true
NEXT_PUBLIC_ENABLE_HOMEWORK=true
NEXT_PUBLIC_ENABLE_PROGRESS_TRACKING=true
NEXT_PUBLIC_ENABLE_TELEHEALTH=true
NEXT_PUBLIC_ENABLE_BILLING_PORTAL=true

# ============================================================
# DEPLOYMENT
# ============================================================
VERCEL_URL=
NEXT_PUBLIC_VERCEL_ENV=development
