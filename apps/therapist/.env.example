# =============================================================
# 24Therapy Therapist Portal (apps/therapist) — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# ============================================================
# API & BACKEND
# ============================================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ============================================================
# AUTHENTICATION
# ============================================================
# NextAuth.js (if using next-auth)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# JWT (used by API client)
NEXT_PUBLIC_JWT_STORAGE_KEY=therapy_access_token
NEXT_PUBLIC_REFRESH_STORAGE_KEY=therapy_refresh_token

# ============================================================
# VIDEO (Daily.co WebRTC)
# ============================================================
NEXT_PUBLIC_DAILY_DOMAIN=your-domain.daily.co

# ============================================================
# FILE STORAGE
# ============================================================
NEXT_PUBLIC_S3_BASE_URL=https://cdn.24therapy.ai
NEXT_PUBLIC_ADMIN_URL=http://localhost:3003
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# ============================================================
# AI FEATURES
# ============================================================
NEXT_PUBLIC_AI_COPILOT_ENABLED=true
NEXT_PUBLIC_AI_SCRIBE_ENABLED=true
NEXT_PUBLIC_AI_MEMORY_ENABLED=true
NEXT_PUBLIC_AI_RISK_RADAR_ENABLED=true

# Copilot streaming endpoint
NEXT_PUBLIC_COPILOT_STREAM_URL=http://localhost:3001/ai/copilot/stream

# ============================================================
# CALENDAR INTEGRATIONS
# ============================================================
# Google Calendar OAuth (for external calendar sync)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ============================================================
# ANALYTICS
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# ERROR TRACKING
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=24therapy
SENTRY_PROJECT=therapist-portal

# ============================================================
# FEATURE FLAGS
# ============================================================
NEXT_PUBLIC_ENABLE_SUPERVISION=true
NEXT_PUBLIC_ENABLE_BILLING=true
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_TEAM_MANAGEMENT=true
NEXT_PUBLIC_ENABLE_AUDIT_LOGS=true

# ============================================================
# HIPAA / COMPLIANCE
# ============================================================
NEXT_PUBLIC_HIPAA_MODE=true
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=240
NEXT_PUBLIC_IDLE_TIMEOUT_MINUTES=30
NEXT_PUBLIC_MFA_REQUIRED=true

# ============================================================
# DEPLOYMENT
# ============================================================
VERCEL_URL=
NEXT_PUBLIC_VERCEL_ENV=development
