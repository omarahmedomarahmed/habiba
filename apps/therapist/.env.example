# =============================================================
# 24Therapy Therapist Portal (apps/therapist) — Environment Variables
# Copy this file to .env.local and fill in your values.
# Only variables actually read by code are listed here.
# =============================================================

# ─── Backend API ──────────────────────────────────────────────────────────────
# Must point to the deployed NestJS backend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ─── App URLs (cross-app navigation) ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_PATIENT_APP_URL=http://localhost:3002
NEXT_PUBLIC_ADMIN_URL=http://localhost:3003
